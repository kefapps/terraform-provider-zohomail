# Copy this file to .env.testacc before loading it in your shell.
# Keep real credentials only in the local .env.testacc file.

TF_ACC=1

# Core provider configuration
ZOHOMAIL_DATA_CENTER=eu
ZOHOMAIL_ORGANIZATION_ID=
ZOHOMAIL_ACCESS_TOKEN=

# OAuth bootstrap inputs used by `make zoho-token`
ZOHOMAIL_CLIENT_ID=
ZOHOMAIL_CLIENT_SECRET=
ZOHOMAIL_AUTHORIZATION_CODE=
ZOHOMAIL_REFRESH_TOKEN=

# DNS-backed acceptance prerequisites
ZOHOMAIL_TEST_DNS_PROVIDER=cloudflare
ZOHOMAIL_TEST_DNS_ZONE_NAME=example.com
ZOHOMAIL_TEST_DNS_BASE_DOMAIN=tfacc.example.com
CLOUDFLARE_API_TOKEN=

# Optional acceptance toggles
ZOHOMAIL_TEST_ENABLE_SLOW_DNS_VERIFICATION=
ZOHOMAIL_TEST_ENABLE_ADVANCED_DOMAIN_FEATURES=
ZOHOMAIL_TEST_ENABLE_MAILBOX_LIFECYCLE=
ZOHOMAIL_TEST_ENABLE_MULTI_MAILBOX=
